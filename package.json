{
  "name": "md-renderer",
  "version": "3.0.0",
  "description": "Render Markdown files from URLs into themed HTML pages via a single HTTP endpoint",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node test.js"
  },
  "dependencies": {
    "compression":            "^1.7.4",
    "express":                "^4.18.2",
    "highlight.js":           "^11.9.0",
    "katex":                  "^0.16.9",
    "lru-cache":              "^10.2.0",
    "markdown-it":            "^14.1.0",
    "markdown-it-abbr":       "^2.0.0",
    "markdown-it-anchor":     "^8.6.7",
    "markdown-it-container":  "^4.0.0",
    "markdown-it-deflist":    "^3.0.0",
    "markdown-it-emoji":      "^3.0.0",
    "markdown-it-footnote":   "^4.0.0",
    "markdown-it-sub":        "^2.0.0",
    "markdown-it-sup":        "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "sanitize-html":          "^2.12.1"
  },
  "engines": { "node": ">=18.0.0" }
}
